node_modules/
dist/
build/
.cache/
.parcel-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# --------------- IDE / Editor ---------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

